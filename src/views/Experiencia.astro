---
import BadgeHabilities from "../components/BadgeHabilities.astro";

interface Props {
    role: string;
    duration: string;     
    responsabilities: string;
    skillsUsed: string[]; // Cambiado a array de strings
}

const { role, duration, responsabilities, skillsUsed } = Astro.props;
---

<article class="glass-card-hover p-5 flex flex-col sm:flex-row gap-5">
    <div class="sm:w-1/4 flex-shrink-0">
        <span class="text-xs font-medium text-white/40 uppercase tracking-wider">
            {duration}
        </span>
    </div>
    <div class="sm:w-3/4 flex flex-col gap-3">
        <h3 class="font-semibold text-white">{role}</h3>
        <p class="text-sm text-white/50 leading-relaxed">
            {responsabilities.split('\n').map((line, index) => (
                <>
                    {line}
                    <br />
                </>
            ))}
        </p>
        <div class="flex flex-wrap gap-1 mt-auto">
            {skillsUsed.map((skill) => (
                <BadgeHabilities>{skill}</BadgeHabilities>
            ))}
        </div>
    </div>
</article>
