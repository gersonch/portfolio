---
import Javascript from "../icons/Javascript.astro";
import AstroIcon from '../icons/AstroIcon.astro'
import React from '../icons/React.astro'
import Node from '../icons/Node.astro'
import Html from '../icons/Html.astro'
import Css from '../icons/Css.astro'
import Tailwind from '../icons/Tailwind.astro'
import Bootstrap from '../icons/Bootstrap.astro'
import PostgreSql from '../icons/PostgreSql.astro'
import Github from "../icons/Github.astro";
import NestJsIcon from "../icons/NestJsIcon.astro";
import ExpoIcon from "../icons/ExpoIcon.astro";
import MongoIcon from "../icons/mongoIcon.astro";
import TypescriptIcon from "../icons/TypescriptIcon.astro";
import Expressjs from "../icons/Expressjs.astro";
---

<section class="flex flex-col gap-y-3 mt-4">
    <h3 class="text-xs font-semibold uppercase tracking-widest text-white/40">
        Tecnologías
    </h3>
    <div class="flex items-center gap-3 flex-wrap opacity-60 hover:opacity-80 transition-opacity duration-300">
        <Javascript />
        <TypescriptIcon />
        <AstroIcon />
        <React />
        <ExpoIcon />
        <Node />
        <Expressjs />
        <Html />
        <Css />
        <Tailwind />
        <Bootstrap />
        <PostgreSql />
        <MongoIcon />
        <Github />
        <NestJsIcon />
    </div>
</section>
